{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    },
    {
      "src": "favicon.ico",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/favicon.ico", "dest": "/favicon.ico" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "^/$", "dest": "/index.html" }
  ]
}
